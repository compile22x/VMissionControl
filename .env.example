# Altnautica Command — Environment Variables
# All variables are optional. Command works standalone with no configuration.

# Demo mode — mock flight engine with 5 simulated drones
# Enabled automatically by `npm run demo`
# NEXT_PUBLIC_DEMO_MODE=true

# Convex backend (optional — cloud fleet management)
# Sign up at https://convex.dev and create a deployment
# NEXT_PUBLIC_CONVEX_URL=

# Cesium Ion token (optional — 3D mission simulation)
# Get a free token at https://ion.cesium.com
# NEXT_PUBLIC_CESIUM_ION_TOKEN=
